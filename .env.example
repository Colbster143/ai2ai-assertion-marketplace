# AI2AI Assertion Marketplace
# Configuration

# API server port (default: 3099)
PORT=3099

# Database path (default: ./data/marketplace.db)
DATABASE_PATH=./data/marketplace.db

# Marketplace fee percentage (default: 10)
MARKETPLACE_FEE_PERCENT=10

# Maximum attestation age before auto-expiry in seconds (default: 90 days)
MAX_ATTESTATION_AGE=7776000

# Lightning Network — pick ONE provider:

# Option A: ZBD (recommended, no setup required)
# 1. Create a free account at https://zbd.gg
# 2. Go to Dashboard → Settings → API Keys
# 3. Copy your Production API key
ZBD_API_KEY=

# Option B: LNBits (self-hosted or public instance)
# LNBITS_URL=https://legend.lnbits.com
# LNBITS_ADMIN_KEY=
